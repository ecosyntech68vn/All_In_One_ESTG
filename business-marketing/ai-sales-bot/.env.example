# === SAO CHÉP FILE NÀY THÀNH ".env" RỒI ĐIỀN ===
# (Không commit .env lên git. Không chia sẻ token/key cho ai.)

# 1) Telegram bot token — lấy từ @BotFather (lệnh /newbot)
TELEGRAM_BOT_TOKEN=

# 2) Chat ID của BẠN (chủ shop) để nhận thông báo lead/đơn.
#    Cách lấy: nhắn cho bot 1 tin, rồi mở:
#    https://api.telegram.org/bot<token>/getUpdates  -> tìm "chat":{"id":...}
OWNER_CHAT_ID=

# 3) AI (tùy chọn nhưng nên có để bot "thông minh").
#    - OpenAI: LLM_BASE_URL=https://api.openai.com/v1 , LLM_MODEL=gpt-4o-mini
#    - Groq (có free tier): LLM_BASE_URL=https://api.groq.com/openai/v1 , LLM_MODEL=llama-3.3-70b-versatile
#    Để trống LLM_API_KEY -> bot vẫn chạy bằng MENU (không cần AI).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 4) Thông tin sản phẩm & thanh toán (bot tự dùng)
PRODUCT_NAME=Cỗ Máy Nội Dung
PRICE=990.000đ
LANDING_URL=
LEAD_MAGNET_URL=
BANK_NAME=
BANK_ACCOUNT=
BANK_HOLDER=
