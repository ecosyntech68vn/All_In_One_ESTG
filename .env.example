# ============================================================
# All_In_One_ESTG — Unified Environment (1 file cho cả 2 service)
# ============================================================
# Copy file này thành .env và điền giá trị. KHÔNG commit .env.
# Trên cloud (Railway/Render): paste từng biến vào UI "Environment".

# --- Telegram (2 BOT TÁCH BIỆT) ---------------------------------
# Tạo từ @BotFather: /newbot. KHÔNG dùng chung 1 bot cho 2 luồng.
BOT_TOKEN_SALES=                # Bot bán hàng số (business-marketing/comay-bot)
BOT_TOKEN_CSKH=                 # Bot chăm sóc KH "AI Thực Chiến" (tro_ly_shop)
ADMIN_CHAT_ID=                  # Chat ID CEO (dùng @userinfobot để lấy)
TELEGRAM_WEBHOOK_SECRET=        # openssl rand -hex 32

# --- AI Agent (chọn 1 hoặc nhiều) -------------------------------
# Tối thiểu 1 key để bot có khả năng tư vấn.
GEMINI_API_KEY=                 # Free tier: https://aistudio.google.com/apikey
CLAUDE_API_KEY=                 # https://console.anthropic.com/
OPENAI_API_KEY=                 # https://platform.openai.com/api-keys
LLM_MODEL=gemini-1.5-flash
LLM_BASE_URL=https://api.openai.com/v1

# --- SePay VietQR (thanh toán) ----------------------------------
# Đăng ký sepay.vn → Cài đặt → API & Webhook
SEPAY_API_KEY=
SEPAY_SECRET_KEY=               # HMAC verification (BẮT BUỘC ở production)
SEPAY_WEBHOOK_URL=

# --- Ngân hàng nhận tiền ----------------------------------------
# Khuyến nghị MB Bank (SePay đẩy biến động realtime).
BANK_ACCOUNT=
BANK_NAME=MB Bank
BANK_CODE=MB                    # VietQR: MB, VCB, TCB, ACB, ...
ACCOUNT_NAME=

# --- Bảo mật ----------------------------------------------------
# Mỗi giá trị: openssl rand -hex 32 (hoặc 64 cho LICENSE_SECRET).
SECRET_KEY=
LICENSE_SECRET=                 # BẮT BUỘC cho license/subscription; dùng chung với Farm OS
CRON_SECRET=                    # Bảo vệ endpoint /cron/renewals
ADMIN_PASSWORD=                 # Mật khẩu đăng nhập /admin dashboard

# --- Database ---------------------------------------------------
# Dev: SQLite ok. Production: chuyển PostgreSQL (tránh race condition multi-container).
DATABASE_URL=sqlite:///shared.db

# --- App settings -----------------------------------------------
BASE_URL=https://your-domain.com
DEBUG=False
RENEW_BEFORE_DAYS=7             # Nhắc gia hạn trước N ngày

# --- Local dev (tùy chọn) ---------------------------------------
PORT=8000
DB_PATH=bot.db
