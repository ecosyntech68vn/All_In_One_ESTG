# ============================================================
# AI Thực Chiến · Bot Sepay · Cấu hình môi trường (CỤC BỘ)
# ============================================================
# Lưu ý: nếu chạy chung trong All_In_One_ESTG, dùng file .env ở root.
# File này chỉ cần khi chạy tro_ly_shop STANDALONE (ngoài monorepo).
# KHÔNG commit .env lên Git. KHÔNG paste giá trị thật vào .env.example.

# --- Telegram ---
# Lấy từ @BotFather: /newbot
BOT_TOKEN=PASTE_NEW_BOT_TOKEN_HERE
ADMIN_CHAT_ID=PASTE_YOUR_TELEGRAM_CHAT_ID

# --- SePay ---
# sepay.vn → Cài đặt → API & Webhook → Tạo API Key
SEPAY_API_KEY=PASTE_SEPAY_API_KEY

# --- Ngân hàng MB Bank (SePay có API trực tiếp) ---
BANK_ACCOUNT=PASTE_BANK_ACCOUNT_NUMBER
BANK_NAME=MB Bank
BANK_OWNER=PASTE_ACCOUNT_OWNER_NAME

# --- URL công khai sau khi deploy ---
BASE_URL=https://your-project.up.railway.app

# --- Mật khẩu Admin Dashboard ---
ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# --- AI Agent — API Keys (chọn 1 trong 3 tuỳ gói khách mua) ---
GEMINI_API_KEY=PASTE_GEMINI_API_KEY
CLAUDE_API_KEY=PASTE_CLAUDE_API_KEY
OPENAI_API_KEY=PASTE_OPENAI_API_KEY

# --- Local dev (tùy chọn) ---
PORT=8000
DB_PATH=bot.db
